<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Détail de la Note</title>
  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      background-color: #f4f7f5;
      padding: 20px;
      margin: 0;
    }
    .detail-container {
      max-width: 600px;
      background: white;
      margin: 40px auto;
      padding: 30px;
      border-radius: 8px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
      border-left: 8px solid #f39c12;
    }
    .meta {
      font-size: 0.9em;
      color: #666;
      border-bottom: 1px solid #eee;
      padding-bottom: 15px;
      margin-bottom: 20px;
    }
    .author { font-weight: bold; color: #2e6f40; }
    .content {
      font-size: 1.1em;
      line-height: 1.6;
      color: #333;
      white-space: pre-line; /* Respecte les retours à la ligne */
    }
    .back-link {
      display: inline-block;
      margin-top: 30px;
      color: #2e6f40;
      text-decoration: none;
      font-weight: bold;
    }
    .back-link:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <div class="detail-container">
    <div class="meta">
      Rapport émis par : <span class="author"><%= message.user %></span><br>
      Date et heure : <%= message.added.toLocaleString('fr-FR') %>
    </div>
    
    <div class="content">
      <%= message.text %>
    </div>

    <a href="/" class="back-link">← Retour au Tableau de Bord</a>
  </div>

</body>
</html>